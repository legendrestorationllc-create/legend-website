# Copy to .env.local and fill in. .env.local is gitignored.

# Canonical production URL (SEO metadata, sitemap, canonical tags, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://legendrestorationct.com

# Google Maps JavaScript API key — powers the /inspection address autocomplete + satellite map.
# Client-side key: restrict it by HTTP referrer in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Contact-form lead destinations (optional). If none are set, the form falls back to mailto.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_SHEETS_WEBHOOK=
NEXT_PUBLIC_GHL_WEBHOOK=
